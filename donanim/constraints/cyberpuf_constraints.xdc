set_property ASYNC_REG true [get_cells -hierarchical -filter {NAME =~ *ro_puf_cekirdek*/ro_a_sync_reg[*]}]
set_property ASYNC_REG true [get_cells -hierarchical -filter {NAME =~ *ro_puf_cekirdek*/ro_b_sync_reg[*]}]
