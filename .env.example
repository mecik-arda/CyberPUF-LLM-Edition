# CyberPUF Environment Configuration
# Copy this file to .env and fill in the values

# Security: AES-256 Key (hex string, 64 characters for 256-bit)
# IMPORTANT: Generate a secure random value!
# Example: openssl rand -hex 32
CYBERPUF_AES_KEY=CHANGE_ME_GENERATE_WITH_COMMAND

# WebSocket Token for real-time communication
# IMPORTANT: Use a strong random token!
WEBSOCKET_TOKEN=CHANGE_ME_GENERATE_WITH_COMMAND

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Subprocess timeout in seconds (max time for single task)
SUBPROCESS_TIMEOUT=600

# Application settings
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=False

# Logging
LOG_LEVEL=INFO
